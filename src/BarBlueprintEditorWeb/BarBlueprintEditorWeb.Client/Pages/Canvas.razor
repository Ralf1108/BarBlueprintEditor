@page "/canvas"

@using SkiaSharp
@using SkiaSharp.Views.Blazor
@using System.Collections.ObjectModel
@using System.Diagnostics
@using BarBlueprintEditor.Shared
@using BarBlueprintEditor.Shared.Models

@inject IJSRuntime Js
@rendermode InteractiveWebAssembly

<img src="https://cdn.prod.website-files.com/5c69241780da2a1dfc6caa4e/655cc7d0f32d12553843bf5f_20231121T0258-9f817473-03c0-43c3-ab45-297f86ad4419.avif" />

<h1>Adaptive Tile Grid Canvas</h1>

<div class="full-page-container">

    <!-- Left sidebar / controls -->
    <aside class="sidebar">
        <h2>Controls</h2>
        <button @onclick="AddEntity">Add Random Entity</button>
        <button @onclick="RemoveLastEntity">Remove Last</button>
        <p>Grid: @GridWidthInTiles × @GridHeightInTiles</p>
        <p>Canvas: @CanvasLogicalWidth × @CanvasLogicalHeight px</p>
        <p>Location: @messageLocation</p>
        <p>Tile: @messageTile</p>
    </aside>

    <!-- Right side: canvas area -->
    <main class="canvas-area">
        <SKCanvasView @ref="canvasView"
                      OnPaintSurface="OnPaintSurface"
                      @onmousedown="HandleMouseDown"
                      Width="@CanvasLogicalWidth"
                      Height="@CanvasLogicalHeight"
                      IgnorePixelScaling="false"
                      class="canvas-view" />
    </main>
</div>

@code {
    private SKCanvasView? canvasView;

    private int GridWidthInTiles { get; set; } = 20;
    private int GridHeightInTiles { get; set; } = 20;
    private int CanvasLogicalWidth => GridWidthInTiles * TileSize;
    private int CanvasLogicalHeight => GridHeightInTiles * TileSize;

    private const int TileSize = 32;
    private const int MinTiles = 8; // don't go too small
    private const int ReservedVerticalPx = 180; // space for header + buttons + margins
    private const int ReservedHorizontalPx = 40;

    private ObservableCollection<Entity> Entities = new();
    private Dictionary<string, SKBitmap> imageCache = new();
    private List<UnitDefinition?> _unitDefinitions = new();

    private string messageLocation = "Click a tile...";
    private string messageTile = "Click a tile...";

    [Inject] public HttpClient Client { get; set; } // Injected HttpClient

