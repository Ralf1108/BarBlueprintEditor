    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Register resize listener
            var dotNetRef = DotNetObjectReference.Create(this);
            await Js.InvokeVoidAsync("browserResize.registerResizeCallback", dotNetRef);

            // Initial size
            await UpdateCanvasSizeFromViewport();
        }
    }

    [JSInvokable]
    public async Task OnBrowserResize()
    {
        await UpdateCanvasSizeFromViewport();
        await InvokeAsync(StateHasChanged); // ensure re-render
    }

    private async Task UpdateCanvasSizeFromViewport()
    {
        var dims = await Js.InvokeAsync<BrowserDimensions>("browserResize.getDimensions");

        // Reserve space for sidebar + some padding
        var availableWidth = dims.Width - ReservedHorizontalPx - 20; // padding
        var availableHeight = dims.Height - ReservedVerticalPx;

        GridWidthInTiles = Math.Max(MinTiles, availableWidth / TileSize);
        GridHeightInTiles = Math.Max(MinTiles, availableHeight / TileSize);

        // Optional: keep square aspect if desired
        GridHeightInTiles = GridWidthInTiles;

        canvasView?.Invalidate();
        await InvokeAsync(StateHasChanged);
    }

    private void OnPaintSurface(SKPaintSurfaceEventArgs e)
    {
        var canvas = e.Surface.Canvas;
        canvas.Clear(SKColors.White);

        // Grid lines (drawn in logical coordinates – SkiaSharp scales automatically)
        using var gridPaint = new SKPaint { Color = new SKColor(220, 220, 220), Style = SKPaintStyle.Stroke, StrokeWidth = 1 };
        for (var i = 0; i <= GridWidthInTiles; i++)
            canvas.DrawLine(i * TileSize, 0, i * TileSize, CanvasLogicalHeight, gridPaint);

        for (var j = 0; j <= GridHeightInTiles; j++)
            canvas.DrawLine(0, j * TileSize, CanvasLogicalWidth, j * TileSize, gridPaint);

        // Draw entities (same as before)
        foreach (var entity in Entities)
        {
            float x = entity.X * TileSize;
            float y = entity.Y * TileSize;

            if (imageCache.TryGetValue(entity.ImageUrl, out var bmp))
            {
                canvas.DrawBitmap(bmp, x, y);
            }
            else
            {
                using var p = new SKPaint { Color = SKColors.IndianRed, Style = SKPaintStyle.Fill };
                canvas.DrawRect(x, y, TileSize, TileSize, p);
            }
        }
    }

    private async Task LoadSampleEntities()
    {
        for (var i = 0; i < 3; i++)
            await AddRandomEntity();

        Entities.CollectionChanged += (_, _) => canvasView?.Invalidate();
    }

    private async Task AddRandomEntity()
    {
        var random = Random.Shared;
        var index = random.Next(_unitDefinitions.Count);
        var unitDefinition = _unitDefinitions[index];
        var x = random.Next(GridWidthInTiles);
        var y = random.Next(GridHeightInTiles);
        // await AddEntityAsync(new Entity { ImageUrl = "https://picsum.photos/32/32?random=1", X = 2, Y = 3 });
        await AddEntityAsync(new Entity { ImageUrl = unitDefinition.ImageUrl, X = x, Y = y });
    }

    private void HandleMouseDown(MouseEventArgs e)
    {
        // canvasView.Dpi is usually window.devicePixelRatio (1, 1.25, 1.5, 2, 2.5, 3 ...)
        var scale = canvasView?.Dpi ?? 1.0;

        var x = e.OffsetX * scale;
        var y = e.OffsetY * scale;

        var tileX = (int)(x / TileSize);
        var tileY = (int)(y / TileSize);

        if (tileX >= 0 && tileX < GridWidthInTiles
                       && tileY >= 0 && tileY < GridHeightInTiles)
        {
            messageLocation = $"{e.OffsetX} x {e.OffsetY}";
            messageTile = $"{tileX} x {tileY}";
        }
        else
        {
            messageLocation = "Outside grid";
            messageTile = "";
        }

        StateHasChanged();
    }

    private async Task AddEntity()
    {
        await AddRandomEntity();
    }

    private async Task AddEntityAsync(Entity entity)
    {
        Entities.Add(entity);
        await LoadImageAsync(entity.ImageUrl);
        canvasView?.Invalidate();
    }

    private void RemoveLastEntity()
    {
        if (Entities.Count > 0)
        {
            Entities.RemoveAt(Entities.Count - 1);
        }
    }

    private async Task LoadImageAsync(string url)
    {
        if (string.IsNullOrEmpty(url) || imageCache.ContainsKey(url))
            return;

        try
        {
            SKBitmap bitmap;
            if(url.EndsWith(".avif", StringComparison.OrdinalIgnoreCase))
            {
                var result = await Js.InvokeAsync<JSImageData>("loadAvifAsImageData", url);
                bitmap = new SKBitmap(result.width, result.height, SKColorType.Rgba8888, SKAlphaType.Premul);

                for (var y = 0; y < result.height; y++)
                {
                    for (var x = 0; x < result.width; x++)
                    {
                        var idx = (y * result.width + x) * 4;
                        var r = result.data[idx + 0];
                        var g = result.data[idx + 1];
                        var b = result.data[idx + 2];
                        var a = result.data[idx + 3];
                        bitmap.SetPixel(x, y, new SKColor(r, g, b, a));
                    }
                }
            }
            else
            {
                var response = await Client.GetAsync(url);
                response.EnsureSuccessStatusCode();
                var stream = await response.Content.ReadAsStreamAsync();
                bitmap = SKBitmap.Decode(stream);
            }

            imageCache[url] = bitmap;
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"Failed to load image {url}: {ex.Message}");
        }
    }

    public class Entity
    {
        public string ImageUrl { get; set; } = string.Empty;
        public int X { get; set; } // Tile index (0-based)
        public int Y { get; set; } // Tile index (0-based)
    }

    public class BrowserDimensions
    {
        public int Width { get; set; }
        public int Height { get; set; }
    }

    public class JSImageData
    {
        public int width { get; set; }
        public int height { get; set; }
        public byte[] data { get; set; }
    }
}